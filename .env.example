# ==============================================================================
# PRism Environment Configuration
# ==============================================================================

# Project metadata
PROJECT_NAME="ReviewSense"
ENVIRONMENT="development" # Set to 'production' in production deployments
API_V1_STR="/api/v1"

# LLM Configuration (Required)
# Get this from https://console.groq.com
GROQ_API_KEY=""

# GitHub Configuration (Required for publishing reviews)
# Generate a Personal Access Token with 'repo' scope
GITHUB_TOKEN=""
# The webhook secret you configured in your GitHub repository webhook settings
GITHUB_WEBHOOK_SECRET=""

# Database Configuration
# Default connection string for the docker-compose postgres container
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/reviewsense"

# Queue Configuration
# Default connection string for the docker-compose redis container
REDIS_URL="redis://redis:6379/0"
